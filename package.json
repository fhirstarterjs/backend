{
   "name": "fhirstarterjs",
   "version": "1.0.8",
   "description": "SMART on FHIR Backend Services (client credentials) auth lifecycle for any FHIR client — JWT assertion, JWKS, and automatic token refresh.",
   "keywords": [
      "fhir",
      "smart-on-fhir",
      "smart",
      "backend-services",
      "smart-backend-services",
      "fhir-auth",
      "fhir-client",
      "fhirclient",
      "oauth",
      "oauth2",
      "client-credentials",
      "jwt",
      "jwt-assertion",
      "jwks",
      "token",
      "token-refresh",
      "access-token",
      "healthcare",
      "hl7",
      "ehr",
      "r4",
      "interoperability"
   ],
   "author": "Joshua Faulkenberry <j@joshuafaulkenberry.com> (https://joshuafaulkenberry.com/)",
   "license": "Kopimi",
   "homepage": "https://github.com/FaulkJ/fhirstarter#readme",
   "repository": {
      "type": "git",
      "url": "git+https://github.com/FaulkJ/fhirstarter.git"
   },
   "bugs": {
      "url": "https://github.com/FaulkJ/fhirstarter/issues"
   },
   "type": "module",
   "main": "./dist/fhirstarter.js",
   "types": "./types/index.d.ts",
   "exports": {
      ".": {
         "types": "./types/index.d.ts",
         "import": "./dist/fhirstarter.js"
      }
   },
   "sideEffects": false,
   "files": [
      "dist",
      "ts",
      "types",
      "README.md",
      "LICENSE.md"
   ],
   "publishConfig": {
      "provenance": true,
      "access": "public"
   },
   "engines": {
      "node": ">=20"
   },
   "scripts": {
      "check": "tsc --noEmit",
      "build": "tsc -p tsconfig.build.json",
      "prepack": "npm run build"
   },
   "dependencies": {
      "jose": "^6.2.3"
   },
   "devDependencies": {
      "@types/node": "^26.0.1",
      "typescript": "^6.0.3"
   }
}
