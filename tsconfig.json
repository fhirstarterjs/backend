{
   "compilerOptions": {
      "target": "ES2022",
      "module": "ESNext",
      "moduleResolution": "bundler",
      "strict": true,
      "esModuleInterop": true,
      "allowSyntheticDefaultImports": true,
      "skipLibCheck": true,
      "allowImportingTsExtensions": true,
      "types": ["node"],
      "noEmit": true
   },
   "include": ["ts", "types", "test"]
}